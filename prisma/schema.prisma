generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BusinessType {
  RETAIL
  SERVICE
  MANUFACTURING
  TECHNOLOGY
  HEALTHCARE
  FINANCE
  EDUCATION
  HOSPITALITY
  OTHER
}

model User {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  age          Int
  email        String       @unique
  location     String
  businessType BusinessType
  passwordHash String
  passwordSalt String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("users")
}
